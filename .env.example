# =============================================================================
# E-CLASS RECORD SYSTEM - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# IMPORTANT: 
# 1. Copy this file and rename to .env (remove .example)
# 2. Fill in all values below
# 3. Keep this file SECURE - never commit to Git or share publicly
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# For cPanel: Use the database name with your cPanel username prefix
# Example: If username is "isuuser" and you create "eclass", use "isuuser_eclass"
DB_HOST=localhost
DB_USER=username_eclass_user
DB_PASSWORD=your_database_password_here
DB_NAME=username_eclass

# -----------------------------------------------------------------------------
# FLASK APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# FLASK_ENV: Set to 'production' for live deployment, 'development' for local
FLASK_ENV=production

# SECRET_KEY: Generate using: python -c "import secrets; print(secrets.token_hex(32))"
# MUST be a long random string for security!
SECRET_KEY=change_this_to_a_very_long_random_string_at_least_50_characters_long

# PRODUCTION_DOMAIN: Your actual domain (NO http:// or https://)
# Examples: 
#   - eclass.isu.edu.ph
#   - yourdomain.com
#   - subdomain.yourdomain.com
PRODUCTION_DOMAIN=yourdomain.com

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (For Forgot Password Feature)
# -----------------------------------------------------------------------------
# Option 1: Gmail (Current working setup)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your_gmail_app_password_here

# Option 2: cPanel Email
# SMTP_SERVER=mail.yourdomain.com
# SMTP_PORT=587
# SENDER_EMAIL=noreply@yourdomain.com
# SENDER_PASSWORD=your_cpanel_email_password

# Option 3: SendGrid (Recommended for production - 100 free emails/day)
# SMTP_SERVER=smtp.sendgrid.net
# SMTP_PORT=587
# SENDER_EMAIL=noreply@yourdomain.com
# SENDER_PASSWORD=your_sendgrid_api_key

# Email sender name (appears in "From" field)
SENDER_NAME=E-Class Record System - ISU Cauayan

# -----------------------------------------------------------------------------
# SECURITY SETTINGS (Production only)
# -----------------------------------------------------------------------------
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# -----------------------------------------------------------------------------
# OPTIONAL SETTINGS
# -----------------------------------------------------------------------------
# Uncomment and configure if needed

# Maximum upload file size (in bytes) - 10MB default
# MAX_CONTENT_LENGTH=10485760

# Timezone
# TIMEZONE=Asia/Manila

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. GENERATE SECRET KEY:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
#
# 2. GET GMAIL APP PASSWORD:
#    - Enable 2FA: https://myaccount.google.com/security
#    - Create App Password: https://myaccount.google.com/apppasswords
#    - Copy 16-character password
#
# 3. SET YOUR DOMAIN:
#    - Use your actual domain without http:// or https://
#    - Example: eclass.isu.edu.ph
#
# 4. VERIFY DATABASE:
#    - Check database name includes cPanel username prefix
#    - Test connection: mysql -u DB_USER -p DB_NAME
#
# 5. INSTALL python-dotenv:
#    pip install python-dotenv
#
# 6. RESTART APPLICATION:
#    - cPanel: Setup Python App → Restart
#    - Or: touch passenger_wsgi.py
#
# =============================================================================
# SECURITY REMINDERS
# =============================================================================
#
# ✓ Never commit .env file to Git (add to .gitignore)
# ✓ Use strong, unique passwords
# ✓ Keep database credentials secure
# ✓ Rotate SECRET_KEY periodically
# ✓ Use HTTPS in production (SSL certificate)
# ✓ Backup this file securely
#
# =============================================================================
